# ─────────────────────────────────────────────
# Homie SaaS — Variables de entorno (.env)
# Copia este archivo como .env y configura los valores
# ─────────────────────────────────────────────

# ── Seguridad JWT ────────────────────────────
# Genera valores únicos con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  OBLIGATORIO en producción — sin esto los tokens se invalidan al reiniciar
SECRET_KEY=3fd99f0069f730b4f0557a0226a5f2cf0dcf04811804feb10c95f605d4126ddd
SUPER_SECRET=b5e83fe12d717b41512fa86d185f02d2bc08581408ba40fbe00dd43a1044423c

# ── Super Admin ──────────────────────────────
# Contraseña inicial. Si está vacía, se genera aleatoria y se imprime al iniciar.
SUPER_ADMIN_INITIAL_PASSWORD=

# ── CORS ─────────────────────────────────────
# Orígenes permitidos, separados por coma
ALLOWED_ORIGINS=http://localhost:3000

# ── Google Maps (geocodificación) ────────────────────────────
# Necesaria para convertir direcciones en coordenadas lat/lng
# Sin esta key se usa Nominatim (OpenStreetMap) como fallback — gratuito pero más lento
# Obtén una en: console.cloud.google.com → Geocoding API
GOOGLE_MAPS_API_KEY=


# Cuenta Gmail que enviará los correos automáticos
GMAIL_USER=tu_cuenta@gmail.com

# Contraseña de APLICACIÓN (no tu contraseña de Gmail)
# Cómo obtenerla:
#   1. Ir a https://myaccount.google.com/security
#   2. Activar "Verificación en 2 pasos" si no está activa
#   3. Buscar "Contraseñas de aplicación"
#   4. Crear una nueva para "Correo" / "Otro dispositivo"
#   5. Copiar las 16 letras generadas (sin espacios)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# ── Frontend URL ────────────────────────────
# URL base del frontend (para generar invite links)
# En producción: https://tudominio.com
FRONTEND_URL=http://localhost:3000

# ── Zona horaria ────────────────────────────
# Los recordatorios se programan en esta zona
# Valor por defecto: America/Santiago
TZ=America/Santiago

# ── MercadoPago ─────────────────────────────
# Credenciales de tu aplicación en MP Developers
# https://www.mercadopago.com.ar/developers/panel

# Access Token (empieza con APP_USR- en producción, TEST- en sandbox)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# Secret para validar webhooks (se genera en MP Developers > Tu app > Webhooks)
MP_WEBHOOK_SECRET=

# Moneda según tu país: CLP (Chile), ARS (Argentina), PEN (Perú), MXN (México)
MP_CURRENCY=CLP

# Precios en la moneda configurada (CLP)
MP_PRICE_PRO=6500
MP_PRICE_ENTERPRISE=12000

# URL pública del backend (para que MP pueda llamar al webhook)
# En desarrollo: usar ngrok o similar → ngrok http 8000
# En producción: https://api.tudominio.com
BACKEND_URL=http://localhost:8000
